# Reference snapshot aktywnego Caddy config na openclaw.
# UWAGA: live config jest w /root/n8n/Caddyfile (NIE ten plik). Caddy container
# mount'uje stamtąd. Ten plik trzymamy w repo żeby śledzić strukturę i zmiany.
# Po edycji live: docker exec caddy caddy reload --config /etc/caddy/Caddyfile
#
# Wszystkie domeny .salespros.pl są A → 159.69.34.23 (openclaw Hetzner).
# Caddy automatycznie wystawia Let's Encrypt SSL dla każdej.

n8n.salespros.pl {
	reverse_proxy n8n:5678
}

bot.salespros.pl {
	reverse_proxy salespros-bot:3000
}

setter.salespros.pl {
	handle /api/* {
		reverse_proxy ig-setter-backend:8000
	}
	handle /webhook/* {
		reverse_proxy ig-setter-backend:8000
	}
	handle {
		reverse_proxy ig-setter-frontend:3000
	}
}

api.salespros.pl {
	reverse_proxy salespros-dashboard-api:8000
	encode gzip
}

dashboard.salespros.pl {
	reverse_proxy salespros-dashboard-web:3000
	encode gzip
}
