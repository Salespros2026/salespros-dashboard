# apps/web/.env.production — produkcyjne env vars dla salespros-dashboard-web (openclaw).
# Skopiować na openclaw do /root/salespros-dashboard/apps/web/.env.production.
# UWAGA: ten plik (.example) jest commitowany. Faktyczny .env.production jest w .gitignore.

# NextAuth
AUTH_SECRET=<openssl rand -base64 32 — to samo co dziś w Vercel>
AUTH_GOOGLE_ID=<z Vercel — google OAuth client ID>
AUTH_GOOGLE_SECRET=<z Vercel — google OAuth client secret>
AUTH_TRUST_HOST=true
AUTH_URL=https://dashboard.salespros.pl
AUTH_ALLOWED_EMAILS=dawiddziadkowiec28@gmail.com,admin@salespros.pl,jonasz.jaworski324@gmail.com

# Backend API (proxy + server-side fetch)
# Wewnątrz Docker network n8n_default — nazwa containera = hostname.
# To omija Caddy/SSL roundtrip, jest szybsze niż https://api.salespros.pl.
API_BASE=http://salespros-dashboard-api:8000
DASHBOARD_API_KEY=<ten sam co w api/.env na openclaw>
PREFER_LIVE=true
