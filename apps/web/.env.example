# Backend FastAPI (server-side only — NIE NEXT_PUBLIC_)
API_BASE=https://api.salespros.app

# Lokalnie: false (snapshoty z dysku); produkcja: true (live API)
PREFER_LIVE=true

# Shared secret z backendem (musi zgadzać się z DASHBOARD_API_KEY w backendzie)
DASHBOARD_API_KEY=<generate-32-char-random>

# NextAuth — Google OAuth (https://console.cloud.google.com → APIs → Credentials)
AUTH_SECRET=<generate-with-openssl rand -base64 32>
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_TRUST_HOST=true

# Whitelist email (CSV) — puste = brak auth (dev only)
AUTH_ALLOWED_EMAILS=dawiddziadkowiec28@gmail.com
